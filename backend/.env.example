GEMINI_API_KEY=your_gemini_api_key
GEMINI_ANALYSIS_MODEL=gemini-3.1-pro-preview
GEMINI_IMAGE_MODEL=gemini-3.1-pro-preview
PERSONA_EXTRACT_MODEL=gemini-3.1-pro-preview
PERSONA_CHAT_MODEL=gemini-3.1-pro-preview
PERSONA_EMBED_MODEL=none
PERSONA_USE_FIRESTORE=false
PERSONA_LOCAL_DEMO_FALLBACK=true
SESSION_USE_FIRESTORE=false
PORT=8080
PUBLIC_BASE_URL=https://your-cloud-run-url.run.app
STORAGE_BUCKET=your-storage-bucket
UPLOAD_OBJECT_PREFIX=uploads/original
MAX_UPLOAD_BYTES=21474836480
RESUMABLE_CHUNK_BYTES=8388608
SAMPLE_ASSET_PREFIX=samples
SAMPLE_COLLECTION=sample_sessions
